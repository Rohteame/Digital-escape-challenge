<%- include("partials/header.ejs") %>
<body id="room3">
	<div class="container text-center d-flex flex-column gap-sm-1 gap-lg-4">
		<div class="top-sec d-flex align-self-center metropolis">
			<div id="timer" class="timer-box fs-3 fw-bold px-3 me-3"></div>
			<div id="restart fs-3">
				<button
					onclick="restartGame()"
					class="btn btn-outline-danger justify-self-center fw-bold"
				>
					<i class="fa-solid fa-rotate-left"></i> Restart
				</button>
			</div>
		</div>
		<div class="header">
			<h1 class="display-3 text-decoration-underline">
				ROOM 3 - The Sync Sinkhole
			</h1>
			<h2>
				You have successfully gained access to your files but you discover these are
				versions from 2023. You need to force a sync to get the latest versions.
			</h2>
		</div>
		<div class="task m-auto text-start">
			<p class="fs-5">
				<span class="fw-bold">Task:</span> You have 5 folders: Desktop, Documents,
				Downloads, C:/Temp, and Pictures. Only 3 are automatically synced when using
				OneDrive. Tick the checkboxes of the 3 correct folders?
			</p>
		</div>
		<div class="container cards-section">
			<div class="row">
				<div class="col">
					<div class="form-check">
						<div class="card align-items-center">
							<img src="/assets/green-file.png" class="img-fluid" alt="" />
							<h6>DESKTOP</h6>
							<input
								class="form-check-input room3-option"
								type="checkbox"
								value="desktop"
							/>
						</div>
					</div>
				</div>
				<div class="col">
					<div class="form-check">
						<div class="card align-items-center">
							<img src="/assets/yello-file.png" class="img-fluid" alt="" />
							<h6>DOCUMENTS</h6>
							<input
								class="form-check-input room3-option"
								type="checkbox"
								value="documents"
							/>
						</div>
					</div>
				</div>
				<div class="col">
					<div class="form-check">
						<div class="card align-items-center">
							<img src="/assets/purple-file.png" class="img-fluid" alt="" />
							<h6>C:/TEMP</h6>
							<input
								class="form-check-input room3-option"
								type="checkbox"
								value="c:/temp"
							/>
						</div>
					</div>
				</div>
				<div class="col">
					<div class="form-check">
						<div class="card align-items-center">
							<img src="/assets/green-file.png" class="img-fluid" alt="" />
							<h6>DOWNLOADS</h6>
							<input
								class="form-check-input room3-option"
								type="checkbox"
								value="downloads"
							/>
						</div>
					</div>
				</div>
				<div class="col">
					<div class="form-check">
						<div class="card align-items-center">
							<img src="/assets/orange-file.png" class="img-fluid" alt="" />
							<h6>PICTURES</h6>
							<input
								class="form-check-input room3-option"
								type="checkbox"
								value="pictures"
							/>
						</div>
					</div>
				</div>
			</div>
		</div>
		<a href="/success" class="btn m-auto secondary-btn metropolis mt-3 disabled"
			>Force Sync <i class="fa-solid fa-arrow-right fs-5"></i
		></a>
	</div>
	<!-- font awesome -->
	<script
		src="https://kit.fontawesome.com/9bf456a39d.js"
		crossorigin="anonymous"
	></script>
	<!-- bootstrap -->
	<script
		src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"
		integrity="sha384-kenU1KFdBIe4zVF0s0G1M5b4hcpxyD9F7jL+jjXkk+Q2h455rYXK/7HAuoJl+0I4"
		crossorigin="anonymous"
	></script>
	<!-- custom JS -->
	<script src="/public/js/main.js"></script>
</body>
<%- include("partials/footer.ejs") %>
