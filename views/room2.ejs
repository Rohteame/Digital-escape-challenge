<%- include("partials/header.ejs") %>

<body id="room2">
	<div
		class="container text-center d-flex justify-content-center flex-column gap-sm-1 gap-lg-3"
	>
		<div class="top-sec d-flex align-self-center metropolis">
			<div id="timer" class="timer-box fs-3 fw-bold px-3 me-3"></div>
			<div id="restart fs-3">
				<button
					onclick="restartGame()"
					class="btn btn-outline-danger justify-self-center fw-bold"
				>
					<i class="fa-solid fa-rotate-left"></i> Restart
				</button>
			</div>
		</div>
		<div class="header">
			<h1 class="display-3 text-decoration-underline">
				ROOM 2 - Phish in the System
			</h1>
			<h2>
				You have now unlocked and gained access to your system but all your files
				and folders look corrupted and inaccessible. You see an email from the IT
				team asking you to verify your backup integrity.
			</h2>
		</div>
		<div class="task m-auto w-50 text-start">
			<p class="fs-5">
				<span class="fw-bold">Task:</span> Spot the safe email to find the recovery
				link.
			</p>
		</div>
		<div class="container cards-section">
			<div class="row">
				<div class="col-sm-6 col-lg-4 mt-2">
					<a
						type="button"
						class="card mt-1"
						data-bs-toggle="modal"
						data-bs-target="#message-modal"
						data-bs-header="✅ Legitimate"
						data-bs-title="Verified & Safe"
						data-bs-body="Correct! This email is legitimate. The sender address (sysadmin@microsoft.com) matches the official domain, the tone is professional, and there is no forced panic or fear-based urgency."
						data-bs-button="Proceed to the Final Room"
						data-bs-correct="true"
					>
						<img src="/assets/sample mail 1.png" class="img-fluid" alt="" />
					</a>
				</div>
				<div class="col-sm-6 col-lg-4 mt-2">
					<a
						type="button"
						class="card mt-1"
						data-bs-toggle="modal"
						data-bs-target="#message-modal"
						data-bs-header="❌ Caught in the Net!"
						data-bs-title="Incorrect. This is a phishing attempt."
						data-bs-body="Sender is from a .org domain (microsoft.org), which is not official. It uses aggressive ALL CAPS and threatens to delete your data within 4 hours to make you act without thinking."
						data-bs-button="Try Again"
						data-bs-correct="false"
					>
						<img src="/assets/sample mail 2.png" class="img-fluid" alt="" />
					</a>
				</div>
				<div class="col-sm-6 col-lg-4 mt-2">
					<a
						type="button"
						class="card mt-1"
						data-bs-toggle="modal"
						data-bs-target="#message-modal"
						data-bs-header="❌ Deceptive Detail"
						data-bs-title="Incorrect. This is a sophisticated typo-squatting attack."
						data-bs-body="Look closely at the sender's email. It says rnicrosoft.com—using an r and an n to mimic the letter m. It also uses a Final Notice threat to create social pressure."
						data-bs-button="Try Again"
						data-bs-correct="false"
					>
						<img src="/assets/sample mail 3.png" class="img-fluid" alt="" />
					</a>
				</div>
			</div>
		</div>
	</div>

	<!-- Modals -->
	<div
		class="modal fade"
		id="message-modal"
		tabindex="-1"
		aria-labelledby="messageModalLabel"
		aria-hidden="true"
		data-bs-backdrop="static"
		data-bs-keyboard="false"
	>
		<div class="modal-dialog">
			<div class="modal-content p-4">
				<div class="modal-header">
					<h1 class="modal-heading fs-3 text-center">...</h1>

					<button
						type="button"
						class="btn-close"
						data-bs-dismiss="modal"
						aria-label="Close"
					></button>
				</div>
				<h1 class="modal-title fs-5" id="messageModalLabel">...</h1>
				<div class="modal-body p-0 mt-2">...</div>
				<div class="modal-footer justify-content-center">
					<button
						type="button"
						class="try-again-btn btn btn-secondary"
						data-bs-dismiss="modal"
					></button>
					<a
						href="/room3"
						type="button"
						class="btn proceed-btn btn-primary hide"
					></a>
				</div>
			</div>
		</div>
	</div>
	<!-- font awesome -->
	<script
		src="https://kit.fontawesome.com/9bf456a39d.js"
		crossorigin="anonymous"
	></script>
	<!-- bootstrap -->
	<script
		src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"
		integrity="sha384-kenU1KFdBIe4zVF0s0G1M5b4hcpxyD9F7jL+jjXkk+Q2h455rYXK/7HAuoJl+0I4"
		crossorigin="anonymous"
	></script>
	<!-- custom JS -->
	<script src="/public/js/main.js"></script>
</body>

<%- include("partials/footer.ejs") %>
